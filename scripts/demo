#!/bin/sh
# Launch the AI-vs-AI demo battle.
#
# Flags explained:
#   --quiet         — suppresses Gradle's build output so only game text shows
#   --console=plain — disables Gradle's rich console, which would otherwise
#                     intercept stdin and break human input

cd "$(dirname "$0")/.."
exec ./gradlew :cli:demo --quiet --console=plain "$@"
